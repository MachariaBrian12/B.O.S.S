                <span className="hl">✅ Restock immediately.</span> 3 units remaining. At 44% growth trajectory you&apos;ll sell out in ~18 hours. Order 24 units today.
              </div>
            </div>
          </div>
        </section>

        {/* ══════════ PRICING ══════════ */}
        <section id="pricing" className="pricing">
          <div className="section-tag reveal">Pricing</div>
          <h2 className="section-title reveal" style={{maxWidth:'100%',margin:'0 auto 0',textAlign:'center'}}>
