              <div className="bento-glow" style={{background:'var(--blue)'}}></div>
            </div>
            <div className="bento-card">
              <div className="bento-icon i-cyan">📦</div>
              <div className="bento-title">Precision Inventory</div>
              <div className="bento-desc">Auto-reorder triggers, expiry tracking, supplier sync. Stockouts become a memory.</div>
              <div className="bento-glow" style={{background:'var(--cyan)'}}></div>
            </div>
            <div className="bento-card">
              <div className="bento-icon i-purple">⚡</div>
              <div className="bento-title">Mobile-First POS</div>
              <div className="bento-desc">Full point-of-sale on any device. Offline-resilient. Auto-syncs the moment you reconnect.</div>
              <div className="bento-glow" style={{background:'var(--purple)'}}></div>
            </div>
            <div className="bento-card">
              <div className="bento-icon i-green">🔲</div>
              <div className="bento-title">Frictionless Payments</div>
