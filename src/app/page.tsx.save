                <li><span className="chk">✓</span>Real-time analytics</li>
                <li><span className="chk">✓</span>Full AI intelligence suite</li>
                <li><span className="chk">✓</span>Multi-store command centre</li>
                <li><span className="chk">✓</span>Staff &amp; shift management</li>
              </ul>
              <button className="p-btn">Start 14-Day Trial</button>
            </div>
            <div className="price-card">
              <div className="p-tier">Enterprise</div>
              <div className="p-price">Custom</div>
              <div className="p-per">tailored to your scale</div>
              <ul className="p-feats">
                <li><span className="chk">✓</span>Everything in Growth</li>
                <li><span className="chk">✓</span>Dedicated account team</li>
                <li><span className="chk">✓</span>Custom integrations &amp; API</li>
                <li><span className="chk">✓</span>Enterprise SLA guarantees</li>
              </ul>
              <button className="p-btn">Talk to Sales</button>
            </div>
