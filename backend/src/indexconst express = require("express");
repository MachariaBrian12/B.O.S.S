
const app = express();

app.use(express.json());

// HEALTH CHECK
app.get("/api/health", (req, res) => {
  res.json({
    status: "ok",
    service: "backend alive",
    time: new Date().toISOString()
  });
});

// USERS EXAMPLE
app.get("/api/users", (req, res) => {
  res.json([
    { id: 1, name: "John Doe" },
    { id: 2, name: "Jane Doe" }
  ]);
});

const PORT = 4000;

app.listen(PORT, () => {
  console.log(`🚀 Backend running on http://localhost:${PORT}`);
});
