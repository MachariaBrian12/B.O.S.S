datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("")
  role      String   @default("user")
  createdAt DateTime @default(now())

  messages Message[]
}

model Message {
  id        String   @id @default(cuid())
  role      String   @default("user")
  content   String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  dayKey     String   @default("")
  weekKey    String   @default("")
  monthKey   String   @default("")
  quarterKey String   @default("")
  yearKey    String   @default("")
}
